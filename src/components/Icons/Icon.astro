---
interface Props {
    text:string,
}
const { text } = Astro.props;
---

<div class="content-icon">
    <div class="icon"><slot /></div>
    <p class="text-center text-icon color-primary ff-sora">{text}</p>
</div>

<style lang="scss" is:global>
    .content-icon {
        width: 130px;
        height: 180px;
        background-color: #140c1c;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        border: 1px solid transparent;
        border-radius: 25px;
    }
    .icon {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 80px;
        width: 80%;
        img {
            object-fit: contain;
            max-width: 60px;
            max-height: 60px;
        }
    }
    .text-icon {
        font-size: 1.4rem;
    }
</style>