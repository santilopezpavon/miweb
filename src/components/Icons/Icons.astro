---
import Icon from "./Icon.astro";
import javascriptIcon from "../../assets/img/javascript.svg";
import phpIcon from "../../assets/img/php.svg";
import cssIcon from "../../assets/img/css.svg";
import htmlIcon from "../../assets/img/html.svg";
import linuxIcon from "../../assets/img/linux.svg";
import nodejsIcon from "../../assets/img/nodejs.svg";
import reactIcon from "../../assets/img/react.svg";
import sqlIcon from "../../assets/img/sql.svg";
import drupalIcon from "../../assets/img/drupal.svg";

import { Image } from "astro:assets";

const data = [
    { text: "Drupal", img: drupalIcon },
    { text: "PHP", img: phpIcon },
    { text: "SQL", img: sqlIcon },
    { text: "JavaScript", img: javascriptIcon },
    { text: "HTML", img: htmlIcon },
    { text: "CSS", img: cssIcon },
    { text: "Linux", img: linuxIcon },
    { text: "NextJS / React", img: reactIcon },
    { text: "NodeJS", img: nodejsIcon },
];
---

<div class="element max-w-screen-xl mx-auto w-11/12">
    <p class="text-lg-red lg:text-lg text-white font-bold mb-14 ff-sora text-center">Tecnologías</p>
    <div class="flex flex-wrap justify-center gap-8">
        {data.map((item) => (
            <Icon text={item.text}>
                <Image src={item.img} alt={item.text} />
            </Icon>
        ))}
    </div>
</div>
